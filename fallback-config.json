{
  "fallback": {
    "primary_provider": "YOUR_PRIMARY_PROVIDER",
    "secondary_provider": "YOUR_SECONDARY_PROVIDER",
    "retry": {
      "primary_retries": 1,
      "primary_retry_delay_seconds": 2
    },
    "fallback_on": {
      "http_status_codes": [429, 500, 502, 503, 504],
      "error_keywords": [
        "timeout",
        "timed out",
        "econnreset",
        "enotfound",
        "eai_again",
        "connection reset",
        "temporary failure"
      ]
    },
    "do_not_fallback_on": {
      "http_status_codes": [400, 401, 403, 404, 422],
      "error_keywords": [
        "invalid api key",
        "authentication",
        "unauthorized",
        "forbidden",
        "bad request",
        "invalid_request_error"
      ]
    }
  },
  "secondary": {
    "base_url": "https://YOUR_SECONDARY_PROVIDER_ENDPOINT/anthropic",
    "env_api_key_name": "YOUR_SECONDARY_API_KEY_ENV_NAME",
    "model_map": {
      "opus": "YOUR_MODEL_NAME_LARGE",
      "sonnet": "YOUR_MODEL_NAME_STANDARD",
      "haiku": "YOUR_MODEL_NAME_FAST"
    }
  },
  "logging": {
    "dir": "~/.claude/logs",
    "file_prefix": "claude-fallback",
    "format": "jsonl"
  }
}
